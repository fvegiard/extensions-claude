{
  "id": "kagi",
  "name": "Kagi Search",
  "description": "Paid, privacy-first search with high signal-to-noise — great for research.",
  "docsUrl": "https://github.com/kagisearch/kagimcp",
  "iconBg": "#FFB319",
  "iconColor": "var(--oh-surface-deep)",
  "keywords": [
    "search",
    "web",
    "privacy"
  ],
  "kind": "mcp",
  "defaultConnectionOptionId": "api",
  "connectionOptions": [
    {
      "id": "api",
      "provider": "mcp",
      "transport": {
        "kind": "stdio",
        "serverName": "kagi",
        "command": "uvx",
        "args": [
          "kagimcp"
        ],
        "envFields": [
          {
            "key": "KAGI_API_KEY",
            "label": "Kagi API key",
            "type": "password",
            "required": true
          }
        ]
      },
      "auth": {
        "strategy": "api_key"
      }
    }
  ]
}
