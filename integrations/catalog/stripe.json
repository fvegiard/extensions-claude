      "provider": "mcp",
      "transport": {
        "kind": "shttp",
        "url": "https://mcp.stripe.com/",
        "apiKeyOptional": true
      },
      "auth": {
        "strategy": "none",
        "apiKeyOptional": true
      }
    }
  ]
}
