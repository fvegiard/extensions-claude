{
  "id": "aws-kb",
  "name": "AWS Knowledge Base",
  "description": "Retrieval-augmented search against AWS Bedrock knowledge bases.",
  "docsUrl": "https://github.com/modelcontextprotocol/servers/tree/main/src/aws-kb-retrieval-server",
  "iconBg": "#FF9900",
  "iconColor": "var(--oh-surface-deep)",
  "keywords": [
    "aws",
    "bedrock",
    "rag",
    "knowledge"
  ],
  "template": {
    "kind": "stdio",
    "serverName": "aws_kb_retrieval",
    "command": "npx",
    "args": [
      "-y",
      "@modelcontextprotocol/server-aws-kb-retrieval"
    ],
    "envFields": [
      {
        "key": "AWS_ACCESS_KEY_ID",
        "label": "AWS access key ID",
        "type": "password",
        "required": true
      },
      {
        "key": "AWS_SECRET_ACCESS_KEY",
        "label": "AWS secret access key",
        "type": "password",
        "required": true
      },
      {
        "key": "AWS_REGION",
        "label": "AWS region",
        "type": "text",
        "placeholder": "us-east-1",
        "required": true
      }
    ]
  }
}
